{
  "description": "boris-says — the real-time coach in your corner: per-prompt quality judge, capability awareness, habit coach.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v node >/dev/null 2>&1 || exit 0; [ -n \"${CLAUDE_PLUGIN_ROOT:-}\" ] && [ -f \"$CLAUDE_PLUGIN_ROOT/dist/hook.js\" ] && node \"$CLAUDE_PLUGIN_ROOT/dist/hook.js\" || exit 0",
            "commandWindows": "if ((Get-Command node -ErrorAction SilentlyContinue) -and $env:CLAUDE_PLUGIN_ROOT -and (Test-Path \"$env:CLAUDE_PLUGIN_ROOT\\dist\\hook.js\")) { node \"$env:CLAUDE_PLUGIN_ROOT\\dist\\hook.js\" }",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v node >/dev/null 2>&1 || exit 0; [ -n \"${CLAUDE_PLUGIN_ROOT:-}\" ] && [ -f \"$CLAUDE_PLUGIN_ROOT/dist/stop-hook.js\" ] && node \"$CLAUDE_PLUGIN_ROOT/dist/stop-hook.js\" || exit 0",
            "commandWindows": "if ((Get-Command node -ErrorAction SilentlyContinue) -and $env:CLAUDE_PLUGIN_ROOT -and (Test-Path \"$env:CLAUDE_PLUGIN_ROOT\\dist\\stop-hook.js\")) { node \"$env:CLAUDE_PLUGIN_ROOT\\dist\\stop-hook.js\" }",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v node >/dev/null 2>&1 || exit 0; [ -n \"${CLAUDE_PLUGIN_ROOT:-}\" ] && [ -f \"$CLAUDE_PLUGIN_ROOT/dist/session-outcome.js\" ] && node \"$CLAUDE_PLUGIN_ROOT/dist/session-outcome.js\" || exit 0",
            "commandWindows": "if ((Get-Command node -ErrorAction SilentlyContinue) -and $env:CLAUDE_PLUGIN_ROOT -and (Test-Path \"$env:CLAUDE_PLUGIN_ROOT\\dist\\session-outcome.js\")) { node \"$env:CLAUDE_PLUGIN_ROOT\\dist\\session-outcome.js\" }",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
