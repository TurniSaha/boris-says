{
  "name": "boris-says",
  "version": "1.0.0",
  "description": "Boris Says — the real-time coach in your corner. Boris Cherny watches how you drive Claude Code and speaks only when it matters. Local-only, no server.",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "TurniSaha",
    "email": "turni.saha@gmail.com"
  },
  "homepage": "https://github.com/TurniSaha/boris-says#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TurniSaha/boris-says.git"
  },
  "bugs": {
    "url": "https://github.com/TurniSaha/boris-says/issues"
  },
  "keywords": [
    "claude-code",
    "claude",
    "plugin",
    "ai-coding",
    "hooks",
    "coach",
    "prompt-engineering"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "catalog:gen": "tsc && node -e \"import('./dist/capability/catalog.js').then(m=>require('fs').writeFileSync('data/catalog.json', JSON.stringify(m.CAPABILITY_CATALOG, null, 2)+'\\n'))\"",
    "refresh-index": "npm run build && node scripts/refresh-skill-index.mjs",
    "gate": "npm run build && vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^2.1.8",
    "typescript": "^5.5.0",
    "vitest": "^2.1.8"
  }
}
